# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS origin (your Vite dev server or deployed URL) ───────────────────────
FRONTEND_URL=http://localhost:5173

# ── Redis (required by Bull queue) ───────────────────────────────────────────
# Option 1: connection URL
# REDIS_URL=redis://localhost:6379

# Option 2: host + port (used when REDIS_URL is not set)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── SQLite database path (defaults to ./pipeline.db) ─────────────────────────
# DB_PATH=/var/data/pipeline.db
