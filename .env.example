# ── Pipeline Dashboard — Docker Compose environment ───────────────────────────
# Copy this file to .env and fill in your values before running:
#   cp .env.example .env

# ── Public host ───────────────────────────────────────────────────────────────
# Used for CORS and informational purposes.
# Set to your server's public IP or domain (no trailing slash).
# Examples:
#   FRONTEND_URL=http://54.123.45.67
#   FRONTEND_URL=https://deploy.mycompany.com
FRONTEND_URL=http://localhost

# ── Port that nginx listens on (host side) ────────────────────────────────────
# Change to 8080 if port 80 is already taken on your host.
PORT=80

# ── Vite build-time API URL ───────────────────────────────────────────────────
# Leave empty — the frontend uses relative URLs (/api/...) and nginx proxies them.
# Only set this if your backend is on a DIFFERENT domain than the frontend.
VITE_API_URL=

# Grop deployment agent (optional)
# Keep the real key in .env only; never commit it.
# If your provider uses a custom API endpoint, set it here.
GROP_API_KEY=
GROP_ENDPOINT=
GROP_MODEL=gemini-2.5-flash
