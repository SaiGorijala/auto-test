# ─── Ollama AI Configuration ───────────────────────────────────────────────────
# Ollama HTTP API endpoint
OLLAMA_URL=http://127.0.0.1:11434

# Default Ollama model for deployment planning
# Models: qwen2.5-coder:3b (fast), qwen2.5-coder:7b (accurate), mistral, neural-chat
OLLAMA_MODEL=qwen2.5-coder:3b

# Ollama request timeout (milliseconds)
OLLAMA_TIMEOUT=120000

# ─── Frontend Configuration ────────────────────────────────────────────────────
# Frontend URL (used for CORS)
FRONTEND_URL=http://localhost:5173

# ─── Database Configuration ────────────────────────────────────────────────────
# SQLite database path (defaults to ./pipeline.db)
DB_PATH=./pipeline.db

# ─── Redis Configuration (for Bull queue) ──────────────────────────────────────
# Redis URL or connection params
# Examples: 
#   redis://:[password]@[host]:[port]/[db]
#   redis://localhost:6379
REDIS_URL=

# Alternative: Individual Redis config
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ─── Docker Configuration ──────────────────────────────────────────────────────
# Docker Hub username for pushing images
DOCKER_USERNAME=

# Docker Hub token/password (use access token)
DOCKER_TOKEN=

# Docker registry URL (default: docker.io)
DOCKER_REGISTRY=docker.io

# ─── Legacy Grop/Gemini Configuration (for error recovery) ──────────────────────
# This is kept for backward compatibility with the existing error recovery system
GROP_API_KEY=
GROP_ENDPOINT=
GROP_MODEL=

# ─── Deployment Logging ───────────────────────────────────────────────────────
# Log level: debug, info, warn, error
LOG_LEVEL=info

# ─── Server Configuration ──────────────────────────────────────────────────────
# Backend port
PORT=3001

# Node environment
NODE_ENV=development
